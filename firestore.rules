rules_version = '2';

// ════════════════════════════════════════════════════════
//  Pitaya OS — Firestore 보안 규칙 Phase 2
//  업데이트: 2026-05-22
//
//  모든 서버 쓰기는 Admin SDK(adminDb)로 처리.
//  클라이언트 직접 쓰기는 ai_conversations/chat_messages 외 전면 차단.
// ════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────
    // users: 본인 프로필만 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /dashboardPresets/{presetId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ──────────────────────────────────────────
    // stores: 인증된 유저 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /stores/{storeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // user_store_map: 본인 것만 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /user_store_map/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // permission_groups: 읽기 허용, 서버만 쓰기
    // ──────────────────────────────────────────
    match /permission_groups/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // role_permissions: 읽기 허용, 서버만 쓰기
    // ──────────────────────────────────────────
    match /role_permissions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // daily_reports: 읽기 허용, 서버만 쓰기
    // ──────────────────────────────────────────
    match /daily_reports/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // hygiene_checklists: 인증된 유저 읽기/쓰기
    // (클라이언트에서 직접 저장하는 기능)
    // ──────────────────────────────────────────
    match /hygiene_checklists/{docId} {
      allow read, write: if request.auth != null;
    }

    // ──────────────────────────────────────────
    // ai_conversations: 본인 것만 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /ai_conversations/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // chat_rooms: 멤버만 읽기, 서버만 쓰기
    // (onSnapshot으로 클라이언트가 직접 구독)
    // ──────────────────────────────────────────
    match /chat_rooms/{roomId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // chat_messages: 방 멤버만 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /chat_messages/{msgId} {
      allow read: if request.auth != null
        && request.auth.uid in
          get(/databases/$(database)/documents/chat_rooms/$(resource.data.roomId)).data.members;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // notifications: 본인 알림만 읽기, 서버만 쓰기
    // (onSnapshot 클라이언트 구독 용도)
    // ──────────────────────────────────────────
    match /notifications/{docId} {
      allow read: if request.auth != null
        && resource.data.targetUid == request.auth.uid;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // pos_customers: 인증된 유저 읽기, 서버만 쓰기
    // (PII는 암호화 저장, 복호화는 API로만)
    // ──────────────────────────────────────────
    match /pos_customers/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // pos_employees: POS 사원 동기화 (서버만 쓰기)
    match /pos_employees/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // pos_customer_sales: 인증된 유저 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /pos_customer_sales/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // customer_decrypt_logs: 읽기 전용 (감사 로그)
    // ──────────────────────────────────────────
    match /customer_decrypt_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /customer_message_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /customer_message_sent/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /customer_request_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /customer_profiles/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /customer_merge_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /notification_queue/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /wiki_pages/{pageId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /versions/{versionId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /files/{fileId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /documents/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /versions/{versionId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /yjs_updates/{updateId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
      match /presence/{uid} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /polls/{pollId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /ballots/{uid} {
        allow read: if false;
        allow write: if false;
      }
    }

    match /hr_calendar_events/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /messenger_calendar_sent/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // pos_sales_header / pos_sales_detail / pos_finish_total / pos_sync_log
    // ──────────────────────────────────────────
    match /pos_sales_header/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /pos_sales_detail/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /pos_finish_total/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /pos_daily_sales/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /store_daily_item_stats/{storeId} {
      allow read: if request.auth != null;
      allow write: if false;
      match /days/{dayId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }
    match /pos_sync_log/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // ai_partner_predictions / ai_partner_accuracy
    // ──────────────────────────────────────────
    match /ai_partner_predictions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /ai_partner_accuracy/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // dashboard_cache / predictions / weather_cache
    // ──────────────────────────────────────────
    match /dashboard_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /predictions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /prediction_analysis_daily/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /weather_cache/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /naver_trend_keywords/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // dashboard_layouts: 슈퍼유저만 쓰기
    // ──────────────────────────────────────────
    match /dashboard_layouts/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email == 'hipona00@gmail.com';
    }

    // ──────────────────────────────────────────
    // 매입관리 컬렉션
    // ──────────────────────────────────────────
    match /purchase_records/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /purchase_items/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /trace_records/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /item_aliases/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /item_match_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /item_prices/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /purchase_chat_logs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // HR / Calendar / Items / Coupons
    // ──────────────────────────────────────────
    match /hr_leave_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_dayoff_requests/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_employees/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_departments/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /calendar_events/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /calendar_todos/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_attendance/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_payroll_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_payroll_runs/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_payroll_slips/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /hr_appointments/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /kakao_oauth_state/{docId} {
      allow read, write: if false;
    }
    match /holiday_kakao_sent/{docId} {
      allow read, write: if false;
    }
    match /sales_hourly_alert_sent/{docId} {
      allow read, write: if false;
    }
    match /sales_hourly_rise_alert_sent/{docId} {
      allow read, write: if false;
    }
    match /items/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /coupons/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /coupon_layouts/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /store_documents/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /suppliers/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // members (legacy) — API 경유 저장
    // ──────────────────────────────────────────
    match /dashboard_widget_permissions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /widget_permissions/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /members/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /purchases/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /customers/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // store_licenses: 인증된 유저 읽기, 서버만 쓰기
    // ──────────────────────────────────────────
    match /store_licenses/{storeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // 매입단가 분석 (도매가 스크래핑)
    // ──────────────────────────────────────────
    match /market_prices/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /market_price_history/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /alias_dictionary/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /scraper_sources/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /scraper_meta/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // signage: 대시보드(인증 쓰기) + TV 디스플레이(승인 콘텐츠 공개 읽기)
    // ──────────────────────────────────────────
    match /signage_content/{docId} {
      allow read: if resource.data.status == 'approved'
        || (request.auth != null);
      allow write: if request.auth != null;
    }
    match /signage_screens/{docId} {
      allow read: if resource.data.isActive == true
        || (request.auth != null);
      allow write: if request.auth != null;
    }
    match /signage_playlist/{storeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /signage_settings/{storeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // 회계관리 (accounting module)
    // ──────────────────────────────────────────
    match /accounting_accounts/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /accounting_vouchers/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /accounting_settings/{storeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /accounting_periods/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ──────────────────────────────────────────
    // 슈퍼유저 헬퍼
    // ──────────────────────────────────────────
    function isSuperuser() {
      return request.auth != null
        && request.auth.token.email == 'hipona00@gmail.com';
    }

    // ──────────────────────────────────────────
    // 정의되지 않은 컬렉션 — 슈퍼유저 읽기 허용, 쓰기 차단
    // ──────────────────────────────────────────
    match /{document=**} {
      allow read: if request.auth != null && isSuperuser();
      allow write: if false;
    }
  }
}
